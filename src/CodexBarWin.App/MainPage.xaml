<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="CodexBarWin.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:CodexBarWin.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">
    <Page.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <local:UsageLevelBrushConverter x:Key="UsageLevelBrushConverter" />
        <TranslateTransform x:Key="SkeletonShimmerTransform" X="-1.25" />
        <LinearGradientBrush
            x:Key="SkeletonShimmerBrush"
            MappingMode="RelativeToBoundingBox"
            RelativeTransform="{StaticResource SkeletonShimmerTransform}"
            StartPoint="0,0"
            EndPoint="1,0">
            <GradientStop Offset="0" Color="{ThemeResource SkeletonFillColor}" />
            <GradientStop Offset="0.38" Color="{ThemeResource SkeletonFillColor}" />
            <GradientStop Offset="0.5" Color="{ThemeResource SkeletonShimmerColor}" />
            <GradientStop Offset="0.62" Color="{ThemeResource SkeletonFillColor}" />
            <GradientStop Offset="1" Color="{ThemeResource SkeletonFillColor}" />
        </LinearGradientBrush>
    </Page.Resources>

    <Grid Padding="22,10,22,14" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListView
            x:Name="ProviderTabs"
            Grid.Row="0"
            HorizontalAlignment="Left"
            AutomationProperties.Name="Enabled providers"
            Background="Transparent"
            ItemsSource="{Binding Tabs}"
            SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
            SelectionChanged="ProviderTabs_SelectionChanged"
            SelectionMode="Single"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.VerticalScrollMode="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="CornerRadius" Value="8" />
                    <Setter Property="Margin" Value="0,0,8,0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinHeight" Value="42" />
                    <Setter Property="MinWidth" Value="40" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ProviderTabViewModel">
                    <Grid
                        Width="40"
                        Height="42"
                        AutomationProperties.Name="{x:Bind DisplayName}"
                        ToolTipService.ToolTip="{x:Bind DisplayName}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="2" />
                        </Grid.RowDefinitions>
                        <local:ProviderLogo
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ProviderKey="{x:Bind ProviderKey}" />
                        <Border
                            Grid.Row="1"
                            Width="18"
                            Height="2"
                            HorizontalAlignment="Center"
                            Background="{StaticResource BrandAccentBrush}"
                            CornerRadius="1"
                            Visibility="{x:Bind IsSelected, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="1">
            <ScrollViewer
                x:Name="UsageContent"
                HorizontalScrollMode="Disabled"
                IsHitTestVisible="False"
                Opacity="0"
                VerticalScrollBarVisibility="Auto"
                Visibility="Collapsed">
                <StackPanel>
                <StackPanel
                    Spacing="14"
                    Visibility="{Binding SelectedProvider.IsAll, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border
                        Padding="2,0,2,12"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                        <StackPanel Spacing="3">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="All providers" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding AllSummaryText}" />
                        </StackPanel>
                    </Border>

                    <ItemsRepeater ItemsSource="{Binding Providers}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:ProviderTabViewModel">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="14"
                                    AutomationProperties.Name="{x:Bind DisplayName}"
                                    Style="{StaticResource ElevatedCardBorderStyle}"
                                    Translation="0,0,8">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <local:ProviderLogo
                                                Width="20"
                                                Height="20"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                ProviderKey="{x:Bind ProviderKey}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind SummaryUpdatedText, Mode=OneWay}" />
                                            <StackPanel
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Spacing="1">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                        Text="{x:Bind CliVersionText, Mode=OneWay}"
                                                        Visibility="{x:Bind HasCliVersion, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                                </StackPanel>
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="{x:Bind PlanText, Mode=OneWay}"
                                                    Visibility="{x:Bind HasPlan, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>

                                        <ProgressBar
                                            Height="3"
                                            IsIndeterminate="True"
                                            Visibility="{x:Bind IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                                        <StackPanel
                                            Orientation="Horizontal"
                                            Spacing="7"
                                            Visibility="{x:Bind HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                            <FontIcon
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Glyph="&#xE7BA;" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind StatusMessage, Mode=OneWay}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>

                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            TextWrapping="Wrap"
                                            Visibility="{x:Bind HasCredits, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                                            <Run Text="Credits · " />
                                            <Run FontWeight="SemiBold" Text="{x:Bind CreditsText, Mode=OneWay}" />
                                        </TextBlock>

                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind EmptyStateMessage}"
                                            Visibility="{x:Bind HasNoUsageData, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}" />

                                        <ItemsRepeater ItemsSource="{x:Bind UsageWindows}">
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="local:UsageWindowViewModel">
                                                    <Border
                                                        Margin="0,2,0,0"
                                                        Padding="0,8,0,4"
                                                        AutomationProperties.Name="{x:Bind AccessibleName, Mode=OneWay}"
                                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                        BorderThickness="0,1,0,0">
                                                        <StackPanel Spacing="6">
                                                            <Grid ColumnSpacing="10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock
                                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                                    TextWrapping="Wrap">
                                                                    <Run Text="{x:Bind DisplayName}" />
                                                                    <Run Text=" · " />
                                                                    <Run FontWeight="SemiBold" Text="{x:Bind PercentText}" />
                                                                </TextBlock>
                                                                <TextBlock
                                                                    Grid.Column="1"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                                    Text="{x:Bind ResetText, Mode=OneWay}"
                                                                    ToolTipService.ToolTip="{x:Bind ExactResetText}" />
                                                            </Grid>
                                                            <ProgressBar
                                                                Height="6"
                                                                Background="{ThemeResource UsageProgressTrackBrush}"
                                                                CornerRadius="3"
                                                                Foreground="{x:Bind UsedPercent, Converter={StaticResource UsageLevelBrushConverter}}"
                                                                Maximum="100"
                                                                MinHeight="6"
                                                                Visibility="{x:Bind HasUsageMeter, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                Value="{x:Bind UsedPercent}">
                                                                <ProgressBar.Resources>
                                                                    <x:Double x:Key="ProgressBarTrackHeight">6</x:Double>
                                                                    <CornerRadius x:Key="ProgressBarTrackCornerRadius">3</CornerRadius>
                                                                </ProgressBar.Resources>
                                                            </ProgressBar>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <StackPanel
                    Spacing="14"
                    Visibility="{Binding SelectedProvider.IsAll, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <Border
                    Padding="2,0,2,12"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid ColumnSpacing="12" RowSpacing="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{Binding SelectedProvider.DisplayName}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding SelectedProvider.CliVersionText}"
                                Visibility="{Binding SelectedProvider.HasCliVersion, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Row="1"
                            AutomationProperties.LiveSetting="Polite"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{Binding SelectedProvider.UpdatedText}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Text="{Binding SelectedProvider.PlanText}"
                            Visibility="{Binding SelectedProvider.HasPlan, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </Border>

                <InfoBar
                    IsClosable="False"
                    IsOpen="{Binding SelectedProvider.HasStatusMessage}"
                    Message="{Binding SelectedProvider.StatusMessage}"
                    Severity="Warning">
                    <InfoBar.ActionButton>
                        <Button
                            AutomationProperties.Name="Try loading this provider again"
                            Click="RetryProviderButton_Click"
                            Content="Try again"
                            Visibility="{Binding SelectedProvider.CanRetry, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <Border
                    Padding="16"
                    AutomationProperties.Name="{Binding SelectedProvider.EmptyStateTitle}"
                    Style="{StaticResource RaisedRowBorderStyle}"
                    Translation="0,0,2"
                    Visibility="{Binding SelectedProvider.HasNoUsageData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Margin="0,1,0,0"
                            VerticalAlignment="Top"
                            FontSize="16"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE946;" />
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="{Binding SelectedProvider.EmptyStateTitle}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding SelectedProvider.EmptyStateMessage}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Padding="14,12"
                    AutomationProperties.Name="{Binding SelectedProvider.CreditsText}"
                    Style="{StaticResource RaisedRowBorderStyle}"
                    Translation="0,0,2"
                    Visibility="{Binding SelectedProvider.HasCredits, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontWeight="SemiBold" Text="Credits" />
                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{Binding SelectedProvider.CreditsText}"
                            TextAlignment="Right"
                            TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <Grid
                    Margin="2,2,2,0"
                    Visibility="{Binding SelectedProvider.HasUsageWindows, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="Rate limits" />
                    <TextBlock
                        Grid.Column="1"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{Binding SelectedProvider.LimitsSummaryText}" />
                </Grid>

                <ItemsRepeater ItemsSource="{Binding SelectedProvider.UsageWindows}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="local:UsageWindowViewModel">
                            <Border
                                Margin="0,0,0,10"
                                Padding="16"
                                AutomationProperties.Name="{x:Bind AccessibleName, Mode=OneWay}"
                                Style="{StaticResource ElevatedCardBorderStyle}"
                                Translation="0,0,8">
                                <StackPanel Spacing="11">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayName}" TextWrapping="Wrap" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                            Text="{x:Bind PercentText}" />
                                    </Grid>
                                    <ProgressBar
                                        Background="{ThemeResource UsageProgressTrackBrush}"
                                        CornerRadius="3"
                                        Height="6"
                                        Foreground="{x:Bind UsedPercent, Converter={StaticResource UsageLevelBrushConverter}}"
                                        Maximum="100"
                                        MinHeight="6"
                                        Visibility="{x:Bind HasUsageMeter, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Value="{x:Bind UsedPercent}">
                                        <ProgressBar.Resources>
                                            <x:Double x:Key="ProgressBarTrackHeight">6</x:Double>
                                            <CornerRadius x:Key="ProgressBarTrackCornerRadius">3</CornerRadius>
                                        </ProgressBar.Resources>
                                    </ProgressBar>
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <FontIcon
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Glyph="&#xE823;" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind ResetText, Mode=OneWay}"
                                            ToolTipService.ToolTip="{x:Bind ExactResetText}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <StackPanel
                    Spacing="10"
                    Visibility="{Binding SelectedProvider.HasResetCredits, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Margin="2,2,2,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontWeight="SemiBold" Text="Limit resets" />
                        <TextBlock
                            Grid.Column="1"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{Binding SelectedProvider.ResetCreditsSummaryText}" />
                    </Grid>

                    <ItemsRepeater ItemsSource="{Binding SelectedProvider.ResetCredits}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:RateLimitResetCreditViewModel">
                                <Border
                                    Margin="0,0,0,6"
                                    Padding="12,10"
                                    AutomationProperties.Name="{x:Bind AccessibleName}"
                                    Style="{StaticResource RaisedRowBorderStyle}"
                                    Translation="0,0,2">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind DisplayName}" />
                                        <StackPanel
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                            <FontIcon
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Glyph="&#xE823;" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="{x:Bind ExpiryText}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <TextBlock
                        Margin="2,0,2,0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{Binding SelectedProvider.ResetCreditsNoticeText}"
                        Visibility="{Binding SelectedProvider.HasResetCreditsNotice, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
                </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid
                x:Name="InitialLoadingState"
                AutomationProperties.LiveSetting="Polite"
                AutomationProperties.Name="Loading usage data">
                <StackPanel Spacing="14">
                    <Border
                        Padding="2,0,2,12"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                        <StackPanel Spacing="3">
                            <TextBlock
                                Style="{StaticResource SubtitleTextBlockStyle}"
                                Text="{Binding SelectedProvider.DisplayName}" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Loading usage data…" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="2,2,2,0">
                        <TextBlock FontWeight="SemiBold" Text="Rate limits" />
                    </Grid>

                    <Border
                        Height="102"
                        Padding="16"
                        AutomationProperties.AccessibilityView="Raw"
                        Style="{StaticResource ElevatedCardBorderStyle}"
                        Translation="0,0,8">
                        <StackPanel Spacing="14">
                            <Rectangle
                                Width="126"
                                Height="14"
                                HorizontalAlignment="Left"
                                Fill="{StaticResource SkeletonShimmerBrush}"
                                RadiusX="7"
                                RadiusY="7" />
                            <Rectangle
                                Height="4"
                                Fill="{StaticResource SkeletonShimmerBrush}"
                                RadiusX="2"
                                RadiusY="2" />
                            <Rectangle
                                Width="92"
                                Height="10"
                                HorizontalAlignment="Left"
                                Fill="{StaticResource SkeletonShimmerBrush}"
                                RadiusX="5"
                                RadiusY="5" />
                        </StackPanel>
                    </Border>

                    <Border
                        Height="102"
                        Padding="16"
                        AutomationProperties.AccessibilityView="Raw"
                        Style="{StaticResource ElevatedCardBorderStyle}"
                        Translation="0,0,8">
                        <StackPanel Spacing="14">
                            <Rectangle
                                Width="174"
                                Height="14"
                                HorizontalAlignment="Left"
                                Fill="{StaticResource SkeletonShimmerBrush}"
                                RadiusX="7"
                                RadiusY="7" />
                            <Rectangle
                                Height="4"
                                Fill="{StaticResource SkeletonShimmerBrush}"
                                RadiusX="2"
                                RadiusY="2" />
                            <Rectangle
                                Width="108"
                                Height="10"
                                HorizontalAlignment="Left"
                                Fill="{StaticResource SkeletonShimmerBrush}"
                                RadiusX="5"
                                RadiusY="5" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Padding="2,6,2,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="7">
                    <ProgressRing
                        Width="16"
                        Height="16"
                        Foreground="{StaticResource BrandAccentBrush}"
                        IsActive="{Binding SelectedProvider.IsLoading}"
                        Visibility="{Binding SelectedProvider.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{Binding AppVersionText}" />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Width="40"
                    Height="40"
                    MinWidth="40"
                    MinHeight="40"
                    Padding="0"
                    AutomationProperties.Name="Refresh all providers"
                    Click="RefreshButton_Click"
                    CornerRadius="20"
                    HorizontalContentAlignment="Center"
                    Style="{StaticResource SubtleButtonStyle}"
                    VerticalContentAlignment="Center"
                    ToolTipService.ToolTip="Refresh all providers">
                    <FontIcon FontSize="16" Glyph="&#xE72C;" IsTextScaleFactorEnabled="False" />
                </Button>
                <Button
                    Grid.Column="2"
                    Width="40"
                    Height="40"
                    MinWidth="40"
                    MinHeight="40"
                    Padding="0"
                    AutomationProperties.Name="{Binding ThemeToggleLabel}"
                    Click="ThemeButton_Click"
                    CornerRadius="20"
                    HorizontalContentAlignment="Center"
                    Style="{StaticResource SubtleButtonStyle}"
                    VerticalContentAlignment="Center"
                    ToolTipService.ToolTip="{Binding ThemeToggleLabel}">
                    <FontIcon
                        FontSize="16"
                        Glyph="{Binding ThemeToggleGlyph}"
                        IsTextScaleFactorEnabled="False" />
                </Button>
                <Button
                    Grid.Column="3"
                    Width="40"
                    Height="40"
                    MinWidth="40"
                    MinHeight="40"
                    Padding="0"
                    AutomationProperties.Name="Open settings"
                    Click="ProvidersButton_Click"
                    CornerRadius="20"
                    HorizontalContentAlignment="Center"
                    Style="{StaticResource SubtleButtonStyle}"
                    VerticalContentAlignment="Center"
                    ToolTipService.ToolTip="Settings">
                    <FontIcon FontSize="16" Glyph="&#xE713;" IsTextScaleFactorEnabled="False" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
