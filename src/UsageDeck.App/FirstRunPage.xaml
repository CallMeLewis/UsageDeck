<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="UsageDeck.App.FirstRunPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UsageDeck.App">
    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Margin="24,16,24,14"
            Spacing="7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    FontSize="24"
                    FontWeight="SemiBold"
                    Text="Set up UsageDeck" />
                <TextBlock
                    x:Name="StepText"
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    AutomationProperties.LiveSetting="Polite"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Step 1 of 3" />
            </Grid>
            <ProgressBar
                x:Name="StepProgress"
                Height="4"
                AutomationProperties.Name="Setup progress"
                Maximum="3"
                Minimum="0"
                Value="1" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="24,0,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <InfoBar
                x:Name="SetupInfoBar"
                Margin="0,0,0,12"
                IsClosable="True"
                IsOpen="False" />

            <ScrollViewer
                x:Name="ProvidersPanel"
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="0,0,8,16" Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Choose providers" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Select the providers you use. UsageDeck checks only this PC."
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ProgressRing
                            x:Name="ProviderDetectionProgress"
                            Width="16"
                            Height="16"
                            AutomationProperties.Name="Checking this PC for providers"
                            IsActive="True" />
                        <TextBlock
                            x:Name="ProviderDetectionText"
                            VerticalAlignment="Center"
                            AutomationProperties.LiveSetting="Polite"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Checking this PC…" />
                    </StackPanel>

                    <Border Style="{StaticResource SettingsGroupBorderStyle}">
                        <ItemsControl ItemsSource="{x:Bind ProviderOptions, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                        <CheckBox
                                            Margin="12,0,0,0"
                                            Padding="12,10"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            AutomationProperties.Name="{Binding AccessibleName}"
                                            Checked="ProviderCheckBox_Changed"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                            ToolTipService.ToolTip="{Binding DiscoveryDetail}"
                                            Unchecked="ProviderCheckBox_Changed">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="128" />
                                                </Grid.ColumnDefinitions>
                                                <local:ProviderLogo
                                                    Width="24"
                                                    Height="24"
                                                    VerticalAlignment="Center"
                                                    ProviderKey="{Binding ProviderKey}" />
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                    <TextBlock
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                        Text="{Binding UsageSource}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <TextBlock
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="{Binding DiscoveryText}"
                                                    TextAlignment="Right"
                                                    TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <TextBlock
                        x:Name="ProviderSelectionHint"
                        AutomationProperties.LiveSetting="Polite"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Select at least one provider to continue."
                        TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer
                x:Name="ThemePanel"
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                Visibility="Collapsed">
                <StackPanel Padding="0,0,8,16" Spacing="18">
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Choose a theme" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Apply the theme to every UsageDeck window."
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Style="{StaticResource SettingsGroupBorderStyle}">
                        <RadioButtons
                            x:Name="ThemeRadioButtons"
                            Margin="12,0,0,8"
                            Padding="16,12"
                            AutomationProperties.Name="App theme"
                            MaxColumns="1"
                            SelectionChanged="ThemeRadioButtons_SelectionChanged">
                            <RadioButton Tag="System">
                                <StackPanel Margin="4,2" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="Use system" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="Match the Windows app theme."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Tag="Light">
                                <StackPanel Margin="4,2" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="Light" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="Keep UsageDeck light."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Tag="Dark">
                                <StackPanel Margin="4,2" Spacing="2">
                                    <TextBlock FontWeight="SemiBold" Text="Dark" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="Keep UsageDeck dark."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </RadioButton>
                        </RadioButtons>
                    </Border>

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="You can change this at any time in Settings."
                        TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer
                x:Name="NotificationsPanel"
                Grid.Row="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                Visibility="Collapsed">
                <StackPanel Padding="0,0,8,16" Spacing="18">
                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Stay ahead of limits" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Choose whether UsageDeck should notify you about important changes."
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Style="{StaticResource SettingsGroupBorderStyle}">
                        <Grid Padding="16" ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="Important notifications" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="Low limits, resets, provider problems and sign-in requirements."
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="UsageDeck establishes a quiet baseline first, so it will not report old changes."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch
                                x:Name="ImportantNotificationsToggle"
                                Grid.Column="1"
                                MinWidth="0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Allow important UsageDeck notifications"
                                OffContent="Off"
                                OnContent="On"
                                Toggled="ImportantNotificationsToggle_Toggled" />
                        </Grid>
                    </Border>

                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Windows delivery" />
                        <Border Style="{StaticResource SettingsGroupBorderStyle}">
                            <StackPanel>
                                <Grid Padding="16,12" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <FontIcon
                                                x:Name="NotificationStatusGlyph"
                                                FontSize="13"
                                                Glyph="&#xE946;" />
                                            <TextBlock
                                                x:Name="NotificationStatusText"
                                                AutomationProperties.LiveSetting="Polite"
                                                FontWeight="SemiBold"
                                                Text="Checking Windows…" />
                                        </StackPanel>
                                        <TextBlock
                                            x:Name="NotificationStatusDetail"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button
                                        x:Name="SendTestNotificationButton"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Click="SendTestNotificationButton_Click"
                                        Content="Send test notification" />
                                </Grid>
                                <Grid
                                    Padding="16,10"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0"
                                    ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="Control banners, sounds and Do not disturb in Windows."
                                        TextWrapping="Wrap" />
                                    <Button
                                        Grid.Column="1"
                                        Click="OpenWindowsNotificationSettingsButton_Click"
                                        Content="Open Windows settings" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="You can change this at any time in Settings."
                        TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid
            Grid.Row="2"
            Margin="0,12,0,0"
            Padding="24,14"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="BackButton"
                MinWidth="88"
                Click="BackButton_Click"
                Content="Back"
                IsEnabled="False" />
            <ProgressRing
                x:Name="SaveProgress"
                Grid.Column="1"
                Width="18"
                Height="18"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                AutomationProperties.Name="Saving setup"
                IsActive="False"
                Visibility="Collapsed" />
            <Button
                x:Name="UseDefaultsButton"
                Grid.Column="2"
                MinWidth="116"
                Click="UseDefaultsButton_Click"
                Content="Use defaults" />
            <Button
                x:Name="ContinueButton"
                Grid.Column="3"
                MinWidth="116"
                Click="ContinueButton_Click"
                Content="Continue"
                IsEnabled="False"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</Page>
