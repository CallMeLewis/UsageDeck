<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="UsageDeck.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon"
    Title="UsageDeck">
    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="SolidBackground"
            Grid.RowSpan="2"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
            IsHitTestVisible="False" />

        <Grid
            x:Name="WindowDragRegion"
            Height="32"
            Background="Transparent">
            <StackPanel
                Margin="12,0,144,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Image
                    Width="16"
                    Height="16"
                    AutomationProperties.AccessibilityView="Raw"
                    Source="ms-appx:///Assets/AppIcon.png" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Opacity="0.72"
                    Text="UsageDeck" />
            </StackPanel>
        </Grid>

        <Frame
            x:Name="RootFrame"
            Grid.Row="1"
            IsNavigationStackEnabled="False" />

        <tb:TaskbarIcon
            x:Name="TrayIcon"
            ContextMenuMode="PopupMenu"
            IconSource="Assets/AppIcon.ico"
            LeftClickCommand="{x:Bind ToggleWindowCommand}"
            MenuActivation="RightClick"
            ToolTipText="UsageDeck usage"
            Visibility="Collapsed">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Command="{x:Bind ShowWindowCommand}" Text="Show usage" />
                    <MenuFlyoutItem Command="{x:Bind RefreshCommand}" Text="Refresh" />
                    <MenuFlyoutItem Command="{x:Bind SettingsCommand}" Text="Settings" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Command="{x:Bind ExitCommand}" Text="Exit" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</Window>
