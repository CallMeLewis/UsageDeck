<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="UsageDeck.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UsageDeck.App"
    Title="UsageDeck settings">
    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="SolidBackground"
            Grid.RowSpan="2"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
            IsHitTestVisible="False" />

        <Grid
            x:Name="SettingsTitleBar"
            Height="32"
            Background="Transparent">
            <TextBlock
                Margin="12,0,144,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="SemiBold"
                Opacity="0.72"
                Text="Settings" />
        </Grid>

        <NavigationView
            x:Name="SettingsNavigation"
            Grid.Row="1"
            AlwaysShowHeader="False"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="True"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            OpenPaneLength="220"
            PaneDisplayMode="Left"
            SelectionChanged="SettingsNavigation_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="General" Tag="general">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Appearance" Tag="appearance">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE790;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="Providers" />
                <NavigationViewItem
                    AutomationProperties.Name="OpenAI Codex provider settings"
                    Tag="provider:codex">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <local:ProviderLogo Width="18" Height="18" ProviderKey="codex" />
                            <TextBlock VerticalAlignment="Center" Text="OpenAI Codex" />
                        </StackPanel>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem
                    AutomationProperties.Name="Claude provider settings"
                    Tag="provider:claude">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <local:ProviderLogo Width="18" Height="18" ProviderKey="claude" />
                            <TextBlock VerticalAlignment="Center" Text="Claude" />
                        </StackPanel>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem
                    AutomationProperties.Name="Antigravity provider settings"
                    Tag="provider:antigravity">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <local:ProviderLogo Width="18" Height="18" ProviderKey="antigravity" />
                            <TextBlock VerticalAlignment="Center" Text="Antigravity" />
                        </StackPanel>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem
                    AutomationProperties.Name="GitHub Copilot provider settings"
                    Tag="provider:copilot">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <local:ProviderLogo Width="18" Height="18" ProviderKey="copilot" />
                            <TextBlock VerticalAlignment="Center" Text="GitHub Copilot" />
                        </StackPanel>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem
                    AutomationProperties.Name="Kiro provider settings"
                    Tag="provider:kiro">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <local:ProviderLogo Width="18" Height="18" ProviderKey="kiro" />
                            <TextBlock VerticalAlignment="Center" Text="Kiro" />
                        </StackPanel>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem
                    AutomationProperties.Name="Amp provider settings"
                    Tag="provider:amp">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <local:ProviderLogo Width="18" Height="18" ProviderKey="amp" />
                            <TextBlock VerticalAlignment="Center" Text="Amp" />
                        </StackPanel>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem
                    AutomationProperties.Name="OpenCode Go provider settings"
                    Tag="provider:opencode-go">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <local:ProviderLogo Width="18" Height="18" ProviderKey="opencode-go" />
                            <TextBlock VerticalAlignment="Center" Text="OpenCode Go" />
                        </StackPanel>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <NavigationViewItem
                    AutomationProperties.Name="Z.AI provider settings"
                    Tag="provider:zai">
                    <NavigationViewItem.Content>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <local:ProviderLogo Width="18" Height="18" ProviderKey="zai" />
                            <TextBlock VerticalAlignment="Center" Text="Z.AI" />
                        </StackPanel>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="About" Tag="about">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid Padding="32,22,32,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <InfoBar
                    x:Name="SettingsInfoBar"
                    Margin="0,0,0,12"
                    VerticalAlignment="Top"
                    IsClosable="True"
                    IsOpen="False" />

                <ScrollViewer
                    x:Name="GeneralPanel"
                    Grid.Row="1"
                    HorizontalContentAlignment="Stretch"
                    HorizontalScrollBarVisibility="Disabled"
                    Padding="0,8,12,0">
                    <StackPanel MaxWidth="620" HorizontalAlignment="Stretch" Spacing="20">
                        <StackPanel Spacing="5">
                            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="General" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Control refresh timing and the tabs shown in the usage window."
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Updates" />
                            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                                <StackPanel>
                                    <Border
                                        Padding="16"
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                                <TextBlock FontWeight="SemiBold" Text="Usage refresh" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="UsageDeck also refreshes once when it starts."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ComboBox
                                                x:Name="RefreshIntervalComboBox"
                                                Grid.Column="1"
                                                MinWidth="160"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="Automatic refresh interval"
                                                SelectionChanged="RefreshIntervalComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Every minute" Tag="1" />
                                                <ComboBoxItem Content="Every 5 minutes" Tag="5" />
                                                <ComboBoxItem Content="Every 15 minutes" Tag="15" />
                                                <ComboBoxItem Content="Every 30 minutes" Tag="30" />
                                            </ComboBox>
                                        </Grid>
                                    </Border>
                                    <Grid Padding="16" ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="160" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center" Spacing="3">
                                            <TextBlock FontWeight="SemiBold" Text="Provider status" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="Check official public status sources every five minutes. No credentials are sent."
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ToggleSwitch
                                            x:Name="StatusMonitoringToggle"
                                            Grid.Column="1"
                                            MinWidth="0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            AutomationProperties.Name="Monitor official provider service status"
                                            OffContent=""
                                            OnContent=""
                                            Toggled="StatusMonitoringToggle_Toggled" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Provider tabs" />
                            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                                <StackPanel>
                                    <Border
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                                <TextBlock FontWeight="SemiBold" Text="All providers tab" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="Show one compact summary containing every enabled provider."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ToggleSwitch
                                                x:Name="AllTabToggle"
                                                Grid.Column="1"
                                                MinWidth="0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                AutomationProperties.Name="Show the All providers tab"
                                                OffContent=""
                                                OnContent=""
                                                Toggled="AllTabToggle_Toggled" />
                                        </Grid>
                                    </Border>
                                    <Grid Padding="16" ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center" Spacing="3">
                                            <TextBlock FontWeight="SemiBold" Text="Default tab" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="Choose the tab shown when UsageDeck starts."
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ComboBox
                                            x:Name="DefaultProviderComboBox"
                                            Grid.Column="1"
                                            MinWidth="170"
                                            AutomationProperties.HelpText="Only enabled providers are available."
                                            AutomationProperties.Name="Default provider tab"
                                            SelectionChanged="DefaultProviderComboBox_SelectionChanged">
                                            <ComboBoxItem Content="All providers" Tag="all" />
                                            <ComboBoxItem Content="OpenAI Codex" Tag="codex" />
                                            <ComboBoxItem Content="Claude" Tag="claude" />
                                            <ComboBoxItem Content="Antigravity" Tag="antigravity" />
                                            <ComboBoxItem Content="GitHub Copilot" Tag="copilot" />
                                            <ComboBoxItem Content="Kiro" Tag="kiro" />
                                            <ComboBoxItem Content="Amp" Tag="amp" />
                                            <ComboBoxItem Content="OpenCode Go" Tag="opencode-go" />
                                            <ComboBoxItem Content="Z.AI" Tag="zai" />
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer
                    x:Name="AppearancePanel"
                    Grid.Row="1"
                    HorizontalContentAlignment="Stretch"
                    HorizontalScrollBarVisibility="Disabled"
                    Padding="0,8,12,0"
                    Visibility="Collapsed">
                    <StackPanel MaxWidth="620" HorizontalAlignment="Stretch" Spacing="20">
                        <StackPanel Spacing="5">
                            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Appearance" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Choose how UsageDeck looks and presents usage on this PC."
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Interface" />
                            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                                <StackPanel>
                                    <Border
                                        Padding="16"
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                                <TextBlock FontWeight="SemiBold" Text="Theme" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="Changes apply immediately to every UsageDeck window."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ComboBox
                                                x:Name="ThemeComboBox"
                                                Grid.Column="1"
                                                MinWidth="160"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="App theme"
                                                SelectionChanged="ThemeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="System" Tag="System" />
                                                <ComboBoxItem Content="Light" Tag="Light" />
                                                <ComboBoxItem Content="Dark" Tag="Dark" />
                                            </ComboBox>
                                        </Grid>
                                    </Border>
                                    <Grid Padding="16" ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="160" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center" Spacing="3">
                                            <TextBlock FontWeight="SemiBold" Text="Translucent background" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="Use the Windows Mica material behind the app."
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ToggleSwitch
                                            x:Name="TranslucencyToggle"
                                            Grid.Column="1"
                                            MinWidth="0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            AutomationProperties.Name="Use translucent window backgrounds"
                                            OffContent=""
                                            OnContent=""
                                            Toggled="TranslucencyToggle_Toggled" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Usage display" />
                            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                                <StackPanel>
                                    <Border
                                        Padding="16"
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                                <TextBlock FontWeight="SemiBold" Text="Usage amount" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="Show quota consumption or the amount still available."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ComboBox
                                                x:Name="UsageValueDisplayComboBox"
                                                Grid.Column="1"
                                                MinWidth="160"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="Usage amount display"
                                                SelectionChanged="UsageValueDisplayComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Used" Tag="Used" />
                                                <ComboBoxItem Content="Remaining" Tag="Remaining" />
                                            </ComboBox>
                                        </Grid>
                                    </Border>
                                    <Grid Padding="16" ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="160" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center" Spacing="3">
                                            <TextBlock FontWeight="SemiBold" Text="Reset time" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="Show a countdown or the exact local date and time."
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                        <ComboBox
                                            x:Name="ResetTimeDisplayComboBox"
                                            Grid.Column="1"
                                            MinWidth="160"
                                            VerticalAlignment="Center"
                                            AutomationProperties.Name="Reset time display"
                                            SelectionChanged="ResetTimeDisplayComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Countdown" Tag="Countdown" />
                                            <ComboBoxItem Content="Time and date" Tag="ExactDateTime" />
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer
                    x:Name="ProviderPanel"
                    Grid.Row="1"
                    HorizontalContentAlignment="Stretch"
                    HorizontalScrollBarVisibility="Disabled"
                    Padding="0,8,12,0"
                    Visibility="Collapsed">
                    <StackPanel MaxWidth="620" HorizontalAlignment="Stretch" Spacing="20">
                        <Border Style="{StaticResource SettingsGroupBorderStyle}">
                            <StackPanel>
                                <Border
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <local:ProviderLogo
                                            x:Name="SelectedProviderLogo"
                                            Width="36"
                                            Height="36"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            x:Name="SelectedProviderTitle"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <ToggleSwitch
                                            x:Name="SelectedProviderToggle"
                                            Grid.Column="2"
                                            MinWidth="0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            AutomationProperties.Name="Enable this provider in the usage window"
                                            OffContent=""
                                            OnContent=""
                                            Toggled="SelectedProviderToggle_Toggled" />
                                    </Grid>
                                </Border>
                                <Border
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16">
                                    <Grid ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="Usage source" />
                                        <TextBlock
                                            x:Name="SelectedProviderSource"
                                            Grid.Column="1"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                                <Border
                                    x:Name="SelectedProviderVersionRow"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16">
                                    <Grid ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="Detected version" />
                                        <TextBlock
                                            x:Name="SelectedProviderVersion"
                                            Grid.Column="1"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                                <Border Padding="16">
                                    <Grid ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="Authentication" />
                                        <TextBlock
                                            x:Name="SelectedProviderAuthentication"
                                            Grid.Column="1"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <StackPanel
                            x:Name="OpenCodeGoConfigurationPanel"
                            Spacing="10"
                            Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold" Text="OpenCode API billing" />
                            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                                <StackPanel>
                                    <Border
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16">
                                        <StackPanel Spacing="6">
                                            <TextBlock FontWeight="SemiBold" Text="Service-account key required" />
                                            <TextBlock
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Text="Use an OpenCode Console service-account API key beginning oc_sk_. Standard OpenCode Go or Zen inference keys cannot export billing usage."
                                                TextWrapping="Wrap" />
                                            <HyperlinkButton
                                                HorizontalAlignment="Left"
                                                NavigateUri="https://console.opencode.ai/guides/usage"
                                                Padding="0"
                                                Content="Open the Usage API guide" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                                <TextBlock FontWeight="SemiBold" Text="Billing history" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="Longer exports add more estimated usage windows."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ComboBox
                                                x:Name="OpenCodeGoUsageRangeComboBox"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                AutomationProperties.Name="OpenCode API billing history range"
                                                SelectionChanged="OpenCodeGoUsageRangeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="1 day · 5-hour estimate" Tag="OneDay" />
                                                <ComboBoxItem Content="7 days · adds 7-day estimate" Tag="SevenDays" />
                                                <ComboBoxItem Content="30 days · all estimates" Tag="ThirtyDays" />
                                            </ComboBox>
                                        </Grid>
                                    </Border>
                                    <Border
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                                <TextBlock FontWeight="SemiBold" Text="API-key storage" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="Changing this does not copy keys between locations."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ComboBox
                                                x:Name="OpenCodeGoApiKeyStorageComboBox"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                SelectionChanged="OpenCodeGoApiKeyStorageComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Windows Credential Manager (recommended)" Tag="WindowsCredentialManager" />
                                                <ComboBoxItem Content="Environment variable" Tag="EnvironmentVariable" />
                                                <ComboBoxItem Content="This session only" Tag="SessionOnly" />
                                            </ComboBox>
                                        </Grid>
                                    </Border>
                                    <Border Padding="16">
                                        <StackPanel Spacing="10">
                                            <StackPanel x:Name="OpenCodeGoManagedKeyPanel" Spacing="8">
                                                <TextBlock FontWeight="SemiBold" Text="Service-account API key" />
                                                <PasswordBox
                                                    x:Name="OpenCodeGoApiKeyBox"
                                                    MaxLength="1024"
                                                    PasswordRevealMode="Peek"
                                                    PlaceholderText="oc_sk_…" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button Click="SaveOpenCodeGoApiKey_Click" Content="Save or replace" />
                                                    <Button Click="RemoveOpenCodeGoApiKey_Click" Content="Remove" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel
                                                x:Name="OpenCodeGoEnvironmentPanel"
                                                Spacing="4"
                                                Visibility="Collapsed">
                                                <TextBlock FontWeight="SemiBold" Text="Environment variable" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="Set OPENCODE_CONSOLE_SERVICE_API_KEY outside UsageDeck, then restart the app. UsageDeck will never write or remove it."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock
                                                x:Name="OpenCodeGoCredentialStatusText"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel
                            x:Name="ZaiConfigurationPanel"
                            Spacing="10"
                            Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold" Text="Z.AI access" />
                            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                                <StackPanel>
                                    <Border
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                                <TextBlock FontWeight="SemiBold" Text="API region" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="Select the region that owns your account."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ComboBox
                                                x:Name="ZaiRegionComboBox"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                SelectionChanged="ZaiRegionComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Global (api.z.ai)" Tag="Global" />
                                                <ComboBoxItem Content="China (open.bigmodel.cn)" Tag="BigModelChina" />
                                            </ComboBox>
                                        </Grid>
                                    </Border>
                                    <Border
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                                <TextBlock FontWeight="SemiBold" Text="API-key storage" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="Changing this does not copy keys between locations."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ComboBox
                                                x:Name="ZaiApiKeyStorageComboBox"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                SelectionChanged="ZaiApiKeyStorageComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Windows Credential Manager (recommended)" Tag="WindowsCredentialManager" />
                                                <ComboBoxItem Content="Environment variable" Tag="EnvironmentVariable" />
                                                <ComboBoxItem Content="This session only" Tag="SessionOnly" />
                                            </ComboBox>
                                        </Grid>
                                    </Border>
                                    <Border Padding="16">
                                        <StackPanel Spacing="10">
                                            <StackPanel x:Name="ZaiManagedKeyPanel" Spacing="8">
                                                <TextBlock FontWeight="SemiBold" Text="API key" />
                                                <PasswordBox
                                                    x:Name="ZaiApiKeyBox"
                                                    MaxLength="1024"
                                                    PasswordRevealMode="Peek"
                                                    PlaceholderText="Enter your Z.AI API key" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button Click="SaveZaiApiKey_Click" Content="Save or replace" />
                                                    <Button Click="RemoveZaiApiKey_Click" Content="Remove" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel
                                                x:Name="ZaiEnvironmentPanel"
                                                Spacing="4"
                                                Visibility="Collapsed">
                                                <TextBlock FontWeight="SemiBold" Text="Environment variable" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="Set Z_AI_API_KEY outside UsageDeck, then restart the app. UsageDeck will never write or remove it."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock
                                                x:Name="ZaiCredentialStatusText"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <TextBlock FontWeight="SemiBold" Text="Service status" />
                            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                                <StackPanel>
                                    <Border
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="Current status" />
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="7">
                                                    <FontIcon
                                                        x:Name="SelectedProviderStatusGlyph"
                                                        FontSize="13"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Glyph="&#xE946;" />
                                                    <TextBlock
                                                        x:Name="SelectedProviderStatusText"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="Checking status…"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock
                                                    x:Name="SelectedProviderStatusDetail"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    TextWrapping="Wrap"
                                                    Visibility="Collapsed" />
                                                <TextBlock
                                                    x:Name="SelectedProviderStatusCheckedText"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Grid Padding="16" ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="Official source" />
                                        <StackPanel Grid.Column="1">
                                            <HyperlinkButton
                                                x:Name="SelectedProviderStatusSourceLink"
                                                Margin="-8,-6,0,-6"
                                                HorizontalAlignment="Left"
                                                Click="OfficialStatusLink_Click"
                                                Content="Open official status" />
                                            <TextBlock
                                                x:Name="SelectedProviderStatusSourceUnavailable"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="No verified public source"
                                                Visibility="Collapsed" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel
                            x:Name="CodexConfigurationPanel"
                            Spacing="10"
                            Visibility="Collapsed">
                            <TextBlock FontWeight="SemiBold" Text="Options" />
                            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                                <Grid Padding="16" ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Spacing="3">
                                        <TextBlock FontWeight="SemiBold" Text="GPT-5.3 Spark" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="Show the separate Spark rate-limit card when Codex reports it."
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ToggleSwitch
                                        x:Name="CodexSparkCardToggle"
                                        Grid.Column="1"
                                        MinWidth="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right"
                                        AutomationProperties.Name="Show the GPT-5.3 Spark usage card"
                                        OffContent=""
                                        OnContent=""
                                        Toggled="CodexSparkCardToggle_Toggled" />
                                </Grid>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer
                    x:Name="AboutPanel"
                    Grid.Row="1"
                    HorizontalContentAlignment="Stretch"
                    HorizontalScrollBarVisibility="Disabled"
                    Padding="0,8,12,0"
                    Visibility="Collapsed">
                    <StackPanel MaxWidth="620" HorizontalAlignment="Stretch" Spacing="24">
                        <StackPanel Spacing="5">
                            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="About" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="A private, native Windows usage monitor for coding providers."
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Updates" />
                            <Border Style="{StaticResource SettingsGroupBorderStyle}">
                                <StackPanel>
                                    <Border
                                        Padding="16,10"
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontWeight="SemiBold"
                                                Text="Check for updates automatically" />
                                            <ToggleSwitch
                                                x:Name="AutomaticUpdatesToggle"
                                                Grid.Column="1"
                                                MinWidth="0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                AutomationProperties.Name="Check for application updates automatically"
                                                OffContent=""
                                                OnContent=""
                                                Toggled="AutomaticUpdatesToggle_Toggled" />
                                        </Grid>
                                    </Border>

                                    <Border
                                        Padding="16,10"
                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Spacing="3">
                                                <TextBlock FontWeight="SemiBold" Text="Update channel" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Text="Choose which release track UsageDeck follows."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <ComboBox
                                                x:Name="UpdateChannelComboBox"
                                                Grid.Column="1"
                                                MinWidth="160"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="Application update channel"
                                                SelectionChanged="UpdateChannelComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Stable" Tag="Stable" />
                                            </ComboBox>
                                        </Grid>
                                    </Border>

                                    <Grid Padding="16,10" ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="VersionText" FontWeight="SemiBold" />
                                            <ProgressBar
                                                x:Name="UpdateProgressBar"
                                                Height="4"
                                                Margin="0,8,0,0"
                                                Maximum="100"
                                                Minimum="0"
                                                Visibility="Collapsed" />
                                        </StackPanel>
                                        <Button
                                            x:Name="UpdateActionButton"
                                            Grid.Column="1"
                                            Width="160"
                                            VerticalAlignment="Center"
                                            Click="UpdateActionButton_Click"
                                            Content="Check for updates" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Padding="16" Style="{StaticResource SettingsGroupBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="UsageDeck" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Usage is collected through local provider tools and fixed provider APIs. App-owned API keys use only the storage location you select, and raw responses are not stored."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
